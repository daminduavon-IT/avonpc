# Copy to migration/.env (gitignored) and fill in. Used by 3-load / 3b-backfill / 4-verify.
#
# The SERVICE_ROLE key BYPASSES Row Level Security — it is SECRET. It lives ONLY
# here for local migration runs. NEVER put it in src/ or the frontend .env.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_dashboard_settings_api
