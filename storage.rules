rules_version = '2';

// Avon Pharmo Chem — Firebase Storage rules.
// Deploy: firebase deploy --only storage
//
// NOTE: bank slips are currently uploaded to Cloudinary (not Firebase
// Storage). These rules cover the admin media/product images that go
// through firestore-services uploadFile(). Adjust paths to your layout.

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public read (product/media images are shown on the storefront),
    // admin-only write, capped at 10 MB and images/PDF only.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
