# Frontend environment variables (Vite) — copy to .env and fill in real values.
# NOTE: VITE_* values are embedded in the client bundle and are NOT secret.

# Supabase (public by design — RLS enforces access; safe in the client bundle)
# Use EITHER the newer publishable key (sb_publishable_...) or the legacy anon key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_sb_publishable_key

# Cloudinary (browser upload) — UNCHANGED by the Supabase migration
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# URL of the Express mailer's quote endpoint (production).
# Defaults to http://localhost:5000/api/quote in development if unset.
VITE_API_URL=https://your-backend-domain.com/api/quote
