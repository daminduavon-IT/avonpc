# Express mailer secrets — copy to server/.env and fill in real values.
# These are SERVER-ONLY. Never commit the real server/.env.

PORT=5000

# SMTP transport (e.g. Gmail with an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_app_password

# Where new-order alerts are sent (falls back to SMTP_USER if unset)
ADMIN_EMAIL=orders@example.com

# Comma-separated list of allowed browser origins for CORS
# e.g. https://avonpc.com,https://www.avonpc.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
